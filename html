<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pong Game</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="container">
        <h1>Pong Game</h1>
        <div class="scoreboard">
            <div class="score">
                <h2>Player</h2>
                <p id="playerScore">0</p>
            </div>
            <div class="score">
                <h2>Computer</h2>
                <p id="computerScore">0</p>
            </div>
        </div>
        <canvas id="pongCanvas" width="1200" height="600"></canvas>
        <div class="controls">
            <p><strong>Controls:</strong></p>
            <p>Mouse: Move up/down to control left paddle</p>
            <p>Arrow Keys: Up/Down to control left paddle</p>
            <p>Computer controls the right paddle automatically</p>
            <button id="startBtn" class="btn">Start Game</button>
            <button id="resetBtn" class="btn">Reset Score</button>
        </div>
    </div>
    <script src="script.js"></script>
</body>
</html>
